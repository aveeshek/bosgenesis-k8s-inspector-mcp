BOSGENESIS_ALLOWED_NAMESPACE=bosgenesis
BOSGENESIS_K8S_AUTH_MODE=kubeconfig
BOSGENESIS_KUBECONFIG_PATH=/path/to/namespace-limited/kubeconfig
BOSGENESIS_API_KEY=replace-me-before-deploy
BOSGENESIS_SETTINGS_FILE=config/settings.yaml
BOSGENESIS_POLICY_FILE=config/policy.yaml
BOSGENESIS_AUDIT_LOG_FILE=./audit.jsonl
BOSGENESIS_OTEL_ENABLED=false
BOSGENESIS_OTEL_EXPORTER_OTLP_ENDPOINT=http://signoz-otel-collector.signoz:4317
BOSGENESIS_OTEL_EXPORTER_OTLP_INSECURE=true
