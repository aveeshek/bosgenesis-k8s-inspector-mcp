flowchart LR
    %% BOS Genesis Kubernetes Inspector MCP System Architecture

    subgraph CLIENTS["Controlled Clients"]
        CODEX["Codex / AI Agent<br/>MCP client"]
        UI["BOS AI Studio<br/>n8n / curl"]
    end

    subgraph SERVICE["BOS Genesis K8s Inspector Service"]
        MCP["MCP Server<br/>stdio tool surface"]
        REST["FastAPI REST API<br/>X-API-Key protected"]
        ROUTER["Tool / API Router<br/>normalized commands"]
        OPS["Operation Layer<br/>list / apply / patch / delete / scale"]
        VALIDATOR["Input Validator<br/>schema and manifest parse"]
        POLICY["Namespace Guard<br/>Policy Engine"]
    end

    subgraph CONFIG["Policy And Configuration Boundary"]
        SETTINGS["settings.yaml / .env<br/>namespace, auth, API key, OTLP endpoint"]
        POLICY_FILE["policy.yaml<br/>allowed resources, blocked kinds, write controls"]
    end

    subgraph K8S["Kubernetes Namespace Boundary"]
        K8S_CLIENT["Kubernetes Python Client<br/>in-cluster or kubeconfig auth"]
        API["Kubernetes API Server<br/>namespaced requests only"]
        RBAC["ServiceAccount<br/>Role + RoleBinding"]
        NS[("Allowed Namespace<br/>bosgenesis only")]
        ALLOWED["Allowed Resources<br/>pods, logs, deployments, services,<br/>ingresses, configmaps, events"]
        BLOCKED["Blocked By Policy<br/>secrets, RBAC, nodes, namespaces,<br/>exec, port-forward, privileged pods"]
    end

    subgraph OBS["Audit And Observability"]
        AUDIT["JSONL Audit Log<br/>actor, action, resource, decision, status"]
        OTEL["OpenTelemetry Spans<br/>request, policy, k8s, audit, latency"]
        SIGNOZ["SigNoz OTel Collector<br/>traces, logs, metrics"]
    end

    CODEX --> MCP
    UI --> REST
    MCP --> ROUTER
    REST --> ROUTER
    ROUTER --> OPS
    OPS --> VALIDATOR
    VALIDATOR --> POLICY
    POLICY -->|allow / deny| OPS

    SETTINGS --> POLICY
    POLICY_FILE --> POLICY

    OPS -->|validated operation| K8S_CLIENT
    K8S_CLIENT --> API
    API --> RBAC
    RBAC --> NS
    NS --> ALLOWED
    POLICY -. reject + audit .-> BLOCKED

    OPS -->|operation events| AUDIT
    OPS -->|trace spans| OTEL
    OTEL --> SIGNOZ

