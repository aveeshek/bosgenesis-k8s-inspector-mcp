    classDef rest fill:#E0F2FE,stroke:#0284C7,color:#075985,stroke-width:2px
    classDef core fill:#F1F5F9,stroke:#475569,color:#334155,stroke-width:2px
    classDef policy fill:#FFEDD5,stroke:#EA580C,color:#7C2D12,stroke-width:2px
    classDef k8s fill:#DCFCE7,stroke:#16A34A,color:#166534,stroke-width:2px
    classDef blocked fill:#FEE2E2,stroke:#DC2626,color:#7F1D1D,stroke-width:2px
    classDef obs fill:#DBEAFE,stroke:#2563EB,color:#1E3A8A,stroke-width:2px
    classDef signoz fill:#EDE9FE,stroke:#7C3AED,color:#4C1D95,stroke-width:2px

    class CODEX,MCP client
    class UI,REST rest
    class ROUTER,OPS,VALIDATOR core
    class POLICY,SETTINGS,POLICY_FILE policy
    class K8S_CLIENT,API,RBAC,NS,ALLOWED k8s
    class BLOCKED blocked
    class AUDIT,OTEL obs
    class SIGNOZ signoz
